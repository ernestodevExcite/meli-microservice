# Mercado Libre OAuth 
# Solo flujo refresh (no OAuth completo). El refresh_token se rota en Mongo.
MELI_CLIENT_ID=your_app_id
MELI_CLIENT_SECRET=your_secret_key
MELI_REFRESH_TOKEN=initial_refresh_token_from_dev_center
MELI_REDIRECT_URI=https://your-domain.com/auth/callback

# Sitio y cuenta 
# MLM = Mexico. Otros: MLA (AR), MLB (BR), MLC (CL), MLU (UY)
MELI_SITE_ID=MLM
# ID de usuario de la inmobiliaria (Int64, no Int32!)
MELI_USER_ID=000000000

# URLs base MELI
MELI_API_BASE_URL=https://api.mercadolibre.com
MELI_AUTH_URL=https://api.mercadolibre.com/oauth/token

# MongoDB
MONGO_URI=mongodb://mongo:27017
MONGO_DB=meli_bridge

# App
LOG_LEVEL=INFO
ENV=local
# Secreto opcional para validar HMAC del webhook del CMS (recomendado)
WEBHOOK_SECRET=
# TimeOut de cliente httpx hacia MELI (segundos)
MELI_HTTP_TIMEOUT=20
